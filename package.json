{
  "name": "ultimate-player",
  "version": "1.3.0",
  "description": "Ultimate Player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "PoXeR (Coded by Gemeni 3)",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.3.0",
    "electron-builder": "^26.15.0",
    "exceljs": "^4.4.0"
  },
  "overrides": {
    "lodash.isequal": "^4.5.0",
    "inflight": "^1.0.6",
    "rimraf": "^6.1.3",
    "glob": "^13.0.6",
    "boolean": "^3.2.0",
    "fstream": "^1.0.12",
    "uuid": "^14.0.0"
  },
  "resolutions": {
    "lodash.isequal": "^4.5.0",
    "inflight": "^1.0.6",
    "rimraf": "^6.1.3",
    "glob": "^13.0.6",
    "boolean": "^3.2.0",
    "fstream": "^1.0.12",
    "uuid": "^14.0.0"
  },
  "build": {
    "appId": "com.ultimate.player",
    "productName": "Ultimate Player",
    "fileAssociations": [
      {
        "ext": [
          "mp4",
          "mkv",
          "webm",
          "avi",
          "mov",
          "ts",
          "m2ts",
          "wmv",
          "flv",
          "3gp",
          "ogv"
        ],
        "name": "Video File",
        "role": "Viewer"
      },
      {
        "ext": [
          "jpg",
          "jpeg",
          "png",
          "gif",
          "webp",
          "bmp",
          "tiff",
          "svg",
          "ico"
        ],
        "name": "Image File",
        "role": "Viewer"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true,
      "shortcutName": "Ultimate Player"
    }
  },
  "type": "commonjs"
}
